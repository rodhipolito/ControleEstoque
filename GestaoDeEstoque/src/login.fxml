<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="exemple.estoque.LoginController"
      spacing="10"
      alignment="CENTER"
      style="-fx-padding: 20;">
    <Label text="Usuário:" />
    <TextField fx:id="usernameField" promptText="Digite seu nome de usuário" />

    <Label text="Senha:" />
    <PasswordField fx:id="passwordField" promptText="Digite sua senha" />

    <Button fx:id="loginButton" text="Login" onAction="#handleLogin" prefWidth="100"/>
</VBox>
